# ─────────────────────────────────────────────────────────────────
# Profit Pathway — environment configuration
# Copy this file to .env and fill in your actual URLs before running.
# ─────────────────────────────────────────────────────────────────

# Engine API endpoints (required for engines to run; leave blank to SKIP).
# These must be deployed API services that return JSON from /health and /process.
# Do not use Vercel frontend/UI URLs unless those deployments implement these APIs.
MARGIN_ENGINE_URL=
DEADSTOCK_ENGINE_URL=
CREDIT_ENGINE_URL=

# Planner API endpoint (required for planner to run; leave blank to SKIP).
PLANNER_URL=

# Optional fallback: comma-separated deployed service base URLs. The orchestrator
# identifies each service by calling its JSON /health endpoint.
ENGINE_URLS=

# How long (seconds) to wait for each engine / planner response
REQUEST_TIMEOUT_S=60

# Directory where JSON exports are written (relative to project root)
EXPORT_DIR=exports

# Comma-separated list of browser UI origins allowed to call this FastAPI backend.
# CORS_ORIGINS does not configure engine or planner endpoints.
# Leave blank to allow all origins (dev default).
# Example: CORS_ORIGINS=https://your-frontend.vercel.app,https://your-other-origin.com
CORS_ORIGINS=

# URL of the FastAPI backend, used by the Streamlit UI.
# In Vercel / production this should be the deployed FastAPI URL.
# Leave blank to run the pipeline in-process (no HTTP hop).
FASTAPI_URL=
