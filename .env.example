# ─────────────────────────────────────────────────────────────────
# Profit Pathway — environment configuration
# Copy this file to .env and fill in your actual URLs before running.
# ─────────────────────────────────────────────────────────────────

# Engine endpoints (required for engines to run; leave blank to SKIP)
MARGIN_ENGINE_URL=
DEADSTOCK_ENGINE_URL=
CREDIT_ENGINE_URL=

# Planner endpoint (required for planner to run; leave blank to SKIP)
PLANNER_URL=

# How long (seconds) to wait for each engine / planner response
REQUEST_TIMEOUT_S=60

# Directory where JSON exports are written (relative to project root)
EXPORT_DIR=exports

# Comma-separated list of allowed CORS origins for the FastAPI backend.
# Leave blank to allow all origins (dev default).
# Example: CORS_ORIGINS=https://your-frontend.vercel.app,https://your-other-origin.com
CORS_ORIGINS=

# URL of the FastAPI backend, used by the Streamlit UI.
# In Vercel / production this should be the deployed FastAPI URL.
# Leave blank to run the pipeline in-process (no HTTP hop).
FASTAPI_URL=
